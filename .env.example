# ==== 1. 自律リサーチ機能 ====
# Tavily Search API キー (https://app.tavily.com/ で取得)
TAVILY_API_KEY=your_tavily_api_key_here

# Ollamaの接続先とモデル名 (Qwen系モデルを想定。事前に `ollama pull qwen2.5` 等でpull済みであること)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5

# ==== 2. 議事録作成機能 ====
# pyannote.audio の話者分離モデル利用に必要なHuggingFaceアクセストークン
# https://huggingface.co/settings/tokens で発行し、
# pyannote/speaker-diarization-3.1 と pyannote/segmentation-3.0 の利用規約に同意しておくこと
HUGGINGFACE_TOKEN=your_huggingface_token_here

# faster-whisperのモデルサイズ (tiny / base / small / medium / large-v3 など)
WHISPER_MODEL_SIZE=large-v3
# 実行デバイス (cpu / cuda)
WHISPER_DEVICE=cpu

# ==== 4. マルチエージェント討論・学習機能 ====
# 討論時に読み込む直近フィードバックの件数
DEBATE_FEEDBACK_CONTEXT_LIMIT=8
# 新規性判定を始めるまでの最低ラウンド数(これより前は必ず継続する)
DEBATE_MIN_ROUNDS_BEFORE_NOVELTY_CHECK=2
# 直近ラウンドの埋め込み類似度がこの値以上なら「新規性が収束した」とみなし、
# max_roundsに達していなくても討論を早期終了する(ASALの収束判定を参考)
DEBATE_NOVELTY_SIMILARITY_THRESHOLD=0.92

# ==== 5. 記憶圧縮システム(Neuro-Memory Architecture) ====
# 新皮質レイヤー(長期記憶)の埋め込みに使うOllamaモデル。事前に `ollama pull nomic-embed-text` が必要
OLLAMA_EMBED_MODEL=nomic-embed-text
# 海馬レイヤー(短期記憶)の生ログ保持日数。これを過ぎたエピソードは睡眠モードで統合後に削除される
MEMORY_RETENTION_DAYS=7
# 会話時に新皮質から呼び出す関連記憶の件数
MEMORY_RECALL_TOP_K=5
# 新皮質に既存メモリと類似度がこの値以上の新規メモリが来た場合、古い方をsuperseded(置き換え)扱いにする
MEMORY_SIMILARITY_THRESHOLD=0.85

# ==== 6. 文学的感性コーパス(Aozora Bunko) ====
# 会話時に文学コーパスから呼び出すスタイルヒントの件数
LITERARY_HINT_TOP_K=2

# ==== 7. 夜間修行(Autonomous Study Loop) ====
# メンターAIとして使うGemini APIキー (https://aistudio.google.com/apikey で取得)
# 那由多さん自身のアカウント/課金になるため、未設定ならこの機能は動作しない(こっそり課金しない設計)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
# 1トピックあたりの志粋⇔メンターの往復回数
STUDY_DIALOGUE_TURNS=3
# 1回の夜間修行で扱う弱点トピックの件数
STUDY_WEAK_TOPICS_COUNT=2

# ==== 9. モデルルーティング ====
# 質問内容(コーディング/推論/雑談)に応じて、その場で最適なローカルモデルへ振り分ける。
# 分類・振り分け先のモデルが未取得の場合は自動でOLLAMA_MODELにフォールバックする
MODEL_ROUTER_ENABLED=true
# 分類専用の軽量モデル。事前に `ollama pull qwen3:1.7b` が必要
# (Qwen3の実際のラインナップは0.6b/1.7b/4b/8b/14b/30b/32b/235bのみ。1.5b/7bは存在しない)
ROUTER_CLASSIFIER_MODEL=qwen3:1.7b
# コーディング・UI設計向け。事前に `ollama pull qwen3-coder:30b` が必要
ROUTER_CODING_MODEL=qwen3-coder:30b
# 論理的考察・推論向け。事前に `ollama pull deepseek-r1:8b` が必要
ROUTER_REASONING_MODEL=deepseek-r1:8b
# 雑談・軽い調べ物向けの軽量モデル。事前に `ollama pull qwen3:8b` が必要
ROUTER_CHAT_MODEL=qwen3:8b
